# Radarr
RADARR_URL=http://radarr:7878
RADARR_API_KEY=

# Sonarr - opzionale
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=

# TMDB
TMDB_BEARER_TOKEN=
COUNTRY=IT
LANGUAGE=it-IT

# Safety
DRY_RUN=true
REMOVE_STALE_TAGS=true

# Tagging
TAG_GENERIC=true
TAG_PROVIDERS=true
GENERIC_TAG=available-streaming
TAG_PREFIX=streaming-

# Provider filter.
# Lascia vuoto per taggare tutti i provider flatrate/free trovati.
# Esempio: Netflix,Amazon Prime Video,Disney Plus,NOW,Apple TV Plus,Paramount Plus,RAI Play
PROVIDER_ALLOWLIST=

# Tipi TMDB da considerare.
# flatrate = incluso abbonamento
# free = gratuito
# ads = gratuito con pubblicità
# rent/buy esclusi di default
OFFER_TYPES=flatrate,free,ads

# SQLite persistence.
# Nel container il path sotto /data viene mantenuto dal volume ./data:/data.
DATABASE_PATH=/data/streaming_checker.sqlite
